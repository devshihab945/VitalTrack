<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    app:strokeWidth="1dp"
    app:strokeColor="#11000000"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:minHeight="104dp">

        <!-- Left icon circle -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/icon_wrap"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8F5E9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_pill"
                android:contentDescription="@string/app_name"
                app:tint="#16A34A" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Delete -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_delete"
            android:contentDescription="delete"
            app:tint="#EF4444"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Toggle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:text="ON"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="12sp"
            android:minWidth="72dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toStartOf="@id/btn_delete"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Name (top row) -->
        <TextView
            android:id="@+id/tv_med_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp"
            android:text="Napa Extra"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/icon_wrap"
            app:layout_constraintEnd_toStartOf="@id/btn_toggle"
            app:layout_constraintTop_toTopOf="@id/icon_wrap" />

        <!-- Dose text MUST be below action row -->
        <TextView
            android:id="@+id/tv_med_dosage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:text="Today 07:00 (After Breakfast • 500mg)"
            android:textColor="#374151"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/tv_med_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_toggle" />

        <!-- Meta below dose -->
        <TextView
            android:id="@+id/tv_med_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Everyday • 3 times"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/tv_med_dosage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_med_dosage"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>